{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "go: build cli-agent-gateway",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-o",
        "bin/cli-agent-gateway.exe",
        "./cmd/server"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "go: test",
      "type": "shell",
      "command": "go",
      "args": ["test", "./..."],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": ["$go"]
    }
  ]
}
