cursor:
  binary_path: cursor-agent          # Windows: cursor-agent.cmd or full path
  # proxy: http://127.0.0.1:7890
  default_model: cursor/composer-2.5-fast
  # OpenCode tool requests use client_tools_agent_mode, not agent_mode
  client_tools_agent_mode: plan
  # workspace: /path/to/project

