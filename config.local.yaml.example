cursor:
  # 本机 cursor-agent 路径（按实际安装位置修改）
  binary_path: C:\Users\chaoj\AppData\Local\cursor-agent\cursor-agent.cmd
  # 本地代理（不需要则留空或删除）
  proxy: http://127.0.0.1:10809
  # default_model: composer-2.5-fast
  # OpenCode 等带 tools 的请求走 client_tools_agent_mode，不是 agent_mode
  client_tools_agent_mode: plan
  # workspace: C:\path\to\your\project

